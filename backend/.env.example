PORT=3000
NODE_ENV=development
JWT_SECRET=change_me_to_a_long_random_secret
FIREBASE_PROJECT_ID=nextlevelfarm

# Render recommended: paste the full Firebase Admin service account JSON as one value.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"nextlevelfarm","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"..."}

# Local development alternative: keep the JSON file uncommitted.
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Optional AI provider keys.
GROQ_API_KEY=
GEMINI_API_KEY=
GEMINI_API_KEY_2=

# Optional external disease/3D proxy service.
DA3_SERVICE_URL=
